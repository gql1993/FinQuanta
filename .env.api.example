# ---------------------------------------------------------------------------
# 推荐策略（模式 A）：API/服务用 PostgreSQL；桌面客户端默认本地 SQLite。
# - 本文件用于 api_server：生产/联调可解开下方 postgres 示例。
# - 桌面 PyQt 勿误配 FINQUANTA_DB_BACKEND=postgres，除非明确要直连同一 PG 做调试。
# ---------------------------------------------------------------------------

FINQUANTA_ENV=prod
FINQUANTA_API_BASE=http://127.0.0.1:9000
FINQUANTA_API_HOST=0.0.0.0
FINQUANTA_API_PORT=9000

# sqlite / postgres（API 侧：开发可 sqlite，生产推荐 postgres）
FINQUANTA_DB_BACKEND=sqlite
FINQUANTA_SQLITE_PATH=data_cache/quant.db

# PostgreSQL example（部署 API 时启用）：
# FINQUANTA_DB_BACKEND=postgres
# FINQUANTA_POSTGRES_DSN=postgresql://finquanta:finquanta@127.0.0.1:5432/finquanta

# Redis example:
# FINQUANTA_REDIS_URL=redis://127.0.0.1:6379/0

FINQUANTA_CORS_ORIGINS=*
FINQUANTA_SNAPSHOT_CACHE_TTL=120
# API 启动时自动拉起后台 daemon。保持 API 常驻即可在工作日无人值守触发调度任务，
# 包括 10:25 的 OpenClaw 自主全流程（选股/研判/风控/执行/归因/学习）。
FINQUANTA_API_AUTOSTART_DAEMON=1
FINQUANTA_DAEMON_BOARDS=人工智能,芯片,量子科技
# Web 运行中心客户端节流缓存（秒）
FINQUANTA_WEB_OPS_CENTER_CACHE_TTL=5
# 告警阈值（第一版，基于内存 metrics 快照）
FINQUANTA_ALERT_APPROVAL_REJECTED_THRESHOLD=5
FINQUANTA_ALERT_APPROVAL_DURATION_MS_THRESHOLD=3000
FINQUANTA_ALERT_EVENT_ERROR_THRESHOLD=10
FINQUANTA_ALERT_APPROVAL_REJECTED_DAILY_THRESHOLD=5
FINQUANTA_ALERT_POLICY_NAME=baseline-v1
FINQUANTA_OBSERVABILITY_TREND_WINDOW_DAYS=7
FINQUANTA_OBSERVABILITY_TREND_EVENT_LIMIT=500
FINQUANTA_TRACE_SAMPLE_RATIO=1.0
FINQUANTA_TRACE_SPAN_BUFFER_SIZE=2000
# FINQUANTA_OTEL_COLLECTOR_ENDPOINT=http://127.0.0.1:4318/v1/traces
FINQUANTA_OTEL_EXPORT_TIMEOUT_SECONDS=5.0
FINQUANTA_OTEL_EXPORT_RETRIES=2
FINQUANTA_OTEL_EXPORT_BACKOFF_SECONDS=0.2
FINQUANTA_OTEL_BREAKER_FAIL_THRESHOLD=3
FINQUANTA_OTEL_BREAKER_COOLDOWN_SECONDS=30
FINQUANTA_OTEL_BATCH_SIZE=100
FINQUANTA_TRACE_VISUAL_BACKEND=otlp
# FINQUANTA_TRACE_VISUAL_BACKEND_BASE_URL=http://127.0.0.1:4318
FINQUANTA_TRACE_VISUAL_TENANT_ID=
FINQUANTA_OBSERVABILITY_READ_TOKEN=
FINQUANTA_STRUCTURED_LOG_PATH=logs/observability/structured.log
FINQUANTA_STRUCTURED_LOG_MAX_BYTES=10485760
FINQUANTA_STRUCTURED_LOG_BACKUP_COUNT=5
FINQUANTA_ALERT_ROUTE_SUPPRESS_SECONDS=300
FINQUANTA_ALERT_ROUTE_ESCALATE_AFTER=3
FINQUANTA_ALERT_ROUTE_DEFAULT_CHANNELS=in_app_feed
FINQUANTA_ALERT_ROUTE_ESCALATION_CHANNELS=wechat_personal
FINQUANTA_ALERT_DISPATCH_RECEIPT_LIMIT=1000
FINQUANTA_OPENCLAW_GATEWAY_ENABLED=1
FINQUANTA_OPENCLAW_GATEWAY_BASE=http://127.0.0.1:18789
# FINQUANTA_OPENCLAW_GATEWAY_HOST=127.0.0.1
# FINQUANTA_OPENCLAW_GATEWAY_PORT=18789
FINQUANTA_OPENCLAW_GATEWAY_TIMEOUT_SECONDS=8.0
# FINQUANTA_OPENCLAW_GATEWAY_TOKEN=
FINQUANTA_OPENCLAW_GATEWAY_PIPELINE_PATHS=/pipeline/run,/openclaw/pipeline/run,/api/openclaw/pipeline/run
FINQUANTA_OPENCLAW_GATEWAY_LEARN_PATHS=/learn/run,/openclaw/learn/run,/api/openclaw/learn/run

# 运行模式（local / platform）。未显式配置时会根据 DB backend 推断。
# FINQUANTA_RUNTIME_MODE=platform

# Feature flags:
# FINQUANTA_FEATURE_OPENCLAW_PIPELINE=1
# FINQUANTA_FEATURE_OPENCLAW_LEARNING=1
# FINQUANTA_FEATURE_TRADE_APPROVAL=1
