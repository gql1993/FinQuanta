{
  "title": "FinQuanta Trace + Alerts + Logs",
  "uid": "finquanta-trace-alerts-logs",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["finquanta", "trace", "alerts", "logs"],
  "templating": {
    "list": [
      {
        "name": "obs_token",
        "type": "textbox",
        "label": "Observability Read Token",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      },
      {
        "name": "trace_id",
        "type": "textbox",
        "label": "Trace ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "title": "Trace Index",
      "type": "table",
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://127.0.0.1:9000/api/observability/dashboard/panel-input?obs_token=${obs_token}",
          "format": "table",
          "root_selector": "data.trace.index"
        }
      ]
    },
    {
      "title": "Current Alerts",
      "type": "table",
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://127.0.0.1:9000/api/observability/dashboard/panel-input?obs_token=${obs_token}",
          "format": "table",
          "root_selector": "data.alerts.current.alerts"
        }
      ]
    },
    {
      "title": "Loki Structured Logs",
      "type": "logs",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "{job=\"finquanta\"} | json | line_format \"{{.timestamp}} {{.level}} {{.event}} trace={{.trace_id}} {{.source}} {{.category}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Collector State",
      "type": "table",
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://127.0.0.1:9000/api/observability/dashboard/panel-input?obs_token=${obs_token}",
          "format": "table",
          "root_selector": "data.collector.state"
        }
      ]
    },
    {
      "title": "Alert Error Rate Hint",
      "type": "stat",
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://127.0.0.1:9000/api/observability/dashboard/panel-input?obs_token=${obs_token}",
          "format": "table",
          "root_selector": "data.alerts.current.summary"
        }
      ]
    },
    {
      "title": "Collector Breaker",
      "type": "stat",
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "targets": [
        {
          "type": "json",
          "source": "url",
          "url": "http://127.0.0.1:9000/api/observability/dashboard/panel-input?obs_token=${obs_token}",
          "format": "table",
          "root_selector": "data.collector.state"
        }
      ]
    }
  ]
}
