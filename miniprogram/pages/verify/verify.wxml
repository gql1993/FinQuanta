<view class="page">
  <view class="title">✅ 走势验证</view>
  <input class="card" placeholder="按策略筛选，如 sepa / canslim" bindinput="onStrategy" value="{{strategy}}" />
  <button class="btn-primary" bindtap="loadData" loading="{{loading}}">刷新验证数据</button>
  <view class="red" wx:if="{{error}}">{{error}}</view>

  <view class="card" wx:if="{{summary}}">
    <view class="list-title">验证汇总</view>
    <view class="list-desc">总信号：{{summary.total}}</view>
    <view class="list-desc">准确率：{{summary.accuracy}}%</view>
    <view class="list-desc">1日均涨：{{summary.avg_pnl_1d}}%</view>
    <view class="list-desc">2日均涨：{{summary.avg_pnl_2d}}%</view>
    <view class="list-desc">3日均涨：{{summary.avg_pnl_3d}}%</view>
    <view class="list-desc">5日均涨：{{summary.avg_pnl_5d}}%</view>
  </view>

  <view class="card">
    <view class="list-title">验证记录</view>
    <view class="list-item" wx:for="{{records}}" wx:key="signal_date" data-index="{{index}}" bindtap="onSelectRecord">
      <view class="list-title">{{item.code}} {{item.name}}</view>
      <view class="list-desc">{{item.strategy}} ｜ {{item.signal_date}} ｜ 评分{{item.score}}</view>
      <view class="list-desc">1日 {{item.pnl_1d}}% ｜ 2日 {{item.pnl_2d}}% ｜ 3日 {{item.pnl_3d}}%</view>
      <view class="list-desc">5日 {{item.pnl_5d}}% ｜ 结果 {{item.correct}}</view>
    </view>
  </view>

  <view class="card" wx:if="{{selected}}">
    <view class="list-title">分析详情</view>
    <view class="list-desc">股票：{{selected.code}} {{selected.name}}</view>
    <view class="list-desc">策略：{{selected.strategy}} ｜ 板块：{{selected.board}}</view>
    <view class="list-desc">信号日：{{selected.signal_date}} ｜ 信号价：{{selected.signal_price}}</view>
    <view class="list-desc">分析原因：{{selected.analysis}}</view>
  </view>
</view>
