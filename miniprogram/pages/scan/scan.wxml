<view class="page">
  <view class="title">📡 选股雷达</view>
  <button class="btn-primary" bindtap="runScan" loading="{{loading}}">立即扫描</button>
  <view class="subtitle">最近更新：{{updatedAt}}</view>
  <view class="red" wx:if="{{error}}">{{error}}</view>

  <view class="card" wx:for="{{items}}" wx:key="代码">
    <view class="list-title">{{item.代码}} {{item.名称}}</view>
    <view class="list-desc">板块：{{item.板块}} | 评分：{{item.评分}} | 价格：{{item.价格}}</view>
    <view class="list-desc blue">{{item.建议买入}}</view>
  </view>
</view>
